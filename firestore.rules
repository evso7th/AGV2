
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create, update: if isOwner(userId);
    }

    match /masterpieces/{document=**} {
      // #ЗАЧЕМ: Публичный доступ к коллекции "Шедевров".
      // #ЧТО: Поддержка get, list и count (агрегации).
      allow read: if true;
      allow create: if isSignedIn();
    }

    match /heritage_axioms/{document=**} {
      // #ЗАЧЕМ: Открытие наследия для всех поколений AuraGroove.
      // #ЧТО: write включает create, update и delete.
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}
