
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents a user profile within AuraGroove.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "username": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "createdAt"]
    },
    "HeritageAxiom": {
      "title": "HeritageAxiom",
      "description": "A musical fragment (lick) from the digitized human heritage. Roles can be specific (e.g., 'accomp piano') for multi-channel reconstruction.",
      "type": "object",
      "properties": {
        "phrase": { "type": "array", "items": { "type": "number" }, "description": "Compressed MIDI data [t, d, deg, tech]" },
        "role": { "type": "string", "description": "Role of the fragment: melody, bass, drums, or 'accomp [instrument_name]'" },
        "compositionId": { "type": "string", "description": "Original track name" },
        "barOffset": { "type": "number", "description": "Offset in bars from start of original track" },
        "bars": { "type": "number", "description": "Total duration in bars" },
        "noteCount": { "type": "number", "description": "Number of notes in the phrase" },
        "genre": { "type": "array", "items": { "type": "string" } },
        "mood": { "type": "array", "items": { "type": "string" } },
        "commonMood": { "type": "array", "items": { "type": "string" } },
        "vector": { 
          "type": "object",
          "properties": {
            "t": { "type": "number" },
            "b": { "type": "number" },
            "e": { "type": "number" },
            "h": { "type": "number" }
          }
        },
        "narrative": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["phrase", "role", "compositionId", "vector"]
    },
    "Masterpiece": {
      "title": "Masterpiece",
      "description": "A saved high-resonance musical configuration.",
      "type": "object",
      "properties": {
        "seed": { "type": "number" },
        "mood": { "type": "string" },
        "genre": { "type": "string" },
        "density": { "type": "number" },
        "bpm": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["anonymous", "password"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "User profiles and settings."
        }
      },
      {
        "path": "/heritage_axioms/{axiomId}",
        "definition": {
          "entityName": "HeritageAxiom",
          "schema": { "$ref": "#/backend/entities/HeritageAxiom" },
          "description": "Global shared library of musical fragments."
        }
      },
      {
        "path": "/masterpieces/{masterpieceId}",
        "definition": {
          "entityName": "Masterpiece",
          "schema": { "$ref": "#/backend/entities/Masterpiece" },
          "description": "Saved musical snapshots with high resonance."
        }
      }
    ]
  }
}
